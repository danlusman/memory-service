# Optional: set bearer auth token for all endpoints except /health
MEMORY_AUTH_TOKEN=

# Optional: max accepted request body size in bytes
MAX_PAYLOAD_BYTES=1048576

# Optional: provide for higher-quality semantic embeddings
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local fallback embedding dimension (used when OPENAI_API_KEY is not set)
EMBEDDING_DIM=128
